# SmarkStock environment — copy to .env.local and fill in. Never commit .env.local.
# Source of truth: FEATURES.md §3.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Claude API (all AI = Claude, NOT Sarvam — FEATURES.md overrides global) ─
ANTHROPIC_API_KEY=
# Master planner model (Opus) e.g. claude-opus-4-1
CLAUDE_MODEL_MASTER=
# Per-item search agent model (Sonnet) e.g. claude-sonnet-4-5
CLAUDE_MODEL_ITEM=

# ── Cloudflare R2 (ALL file storage: BOMs, labels, receipts, docs, exports) ─
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=smarkstock-files
CLOUDFLARE_R2_ENDPOINT=

# ── Distributor APIs (more keys addable via Settings; keys stay server-side) ─
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
MOUSER_API_KEY=
ELEMENT14_API_KEY=

# ── Email (Resend — client-facing sourcing reminders) ───────────────────────
RESEND_API_KEY=
# Verified-domain from-address in the Resend account, e.g. "SmarkStock <noreply@yourdomain.com>"
EMAIL_FROM=
# Shared secret the cron route checks (Authorization: Bearer <secret> or x-cron-secret header)
CRON_SECRET=
# Public site origin used to build the /p/:share_token link in reminder emails
# (falls back to Vercel's VERCEL_URL, then localhost — see lib/url.ts)
NEXT_PUBLIC_APP_URL=

# ── Browser worker ──────────────────────────────────────────────────────────
WORKER_SHARED_SECRET=
# one of: computeruse | playwright | browserbase
BROWSER_DRIVER=computeruse
# Remote Chromium WS endpoint for PlaywrightDriver's connectOverCDP (e.g. a Hetzner
# box), full URL incl. auth token. Inert until BROWSER_DRIVER=playwright AND
# ALLOW_LIVE_BROWSER=1 (Phase-0 gate — FEATURES.md §0).
PLAYWRIGHT_WS_ENDPOINT=
